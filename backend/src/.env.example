# ============================================================================
# ELOT AI — Backend environment variables (example)
# Copy to src/.env and edit. AI keys are optional — without them the
# demo falls back to deterministic sample content.
# ============================================================================

# ------------- app -------------
APP_NAME="ELOT AI"
APP_DESCRIPTION="Employee Learning & Onboarding Trainer — AI-powered corporate training"
APP_VERSION="0.1.0"
CONTACT_NAME="ELOT AI Team"
CONTACT_EMAIL="hello@elot.ai"
LICENSE_NAME="MIT"

# ------------- database -------------
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=postgres
POSTGRES_SERVER="db"
POSTGRES_PORT=5432
POSTGRES_DB="elot"
POSTGRES_ASYNC_PREFIX="postgresql+asyncpg://"

# ------------- security -------------
# Generate with: openssl rand -hex 32
SECRET_KEY=de2132a4a3a029d6a93a2aefcb519f0219990f92ca258a7c5ed938a444dbe1c8
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------------- admin -------------
ADMIN_NAME="admin"
ADMIN_EMAIL="admin@elot.ai"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="ChangeMe!2026"

# ------------- redis -------------
REDIS_CACHE_HOST="redis"
REDIS_CACHE_PORT=6379
REDIS_QUEUE_HOST="redis"
REDIS_QUEUE_PORT=6379
REDIS_RATE_LIMIT_HOST="redis"
REDIS_RATE_LIMIT_PORT=6379
CLIENT_CACHE_MAX_AGE=60

# ------------- CORS — allow the Vite dev server -------------
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://localhost:4173"]
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# ------------- environment -------------
ENVIRONMENT="local"
TIER_NAME="free"

# ============================================================================
# AI providers (optional) — server-side only, never expose in the frontend.
# OpenAI is tried first when both are set. If both are missing, the AI
# service uses deterministic sample content so the demo never breaks.
# ============================================================================

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash-latest
