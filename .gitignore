# Playwright transient output. The *.webm + *.gif under artifacts/demo/ are
# intentionally committed (README references them); everything else under
# artifacts/test-results/ is regenerated on every run.
artifacts/test-results/
artifacts/demo/.last-run.json

# Video-pipeline intermediates. Only the final MP4s (elot-final.mp4,
# elot-veo.mp4) are committed — audio + per-scene clips regenerate.
artifacts/video/audio/
artifacts/video/clips/
artifacts/video/veo/
artifacts/video/concat.txt

# Local agent / IDE config
.claude/
